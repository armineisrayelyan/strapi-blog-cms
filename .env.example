# =============================================================================
# Local development
# =============================================================================
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# Secrets — generate unique values for each environment
# Run: openssl rand -base64 16 (repeat 4 times for APP_KEYS)
APP_KEYS=replaceWithKey1,replaceWithKey2,replaceWithKey3,replaceWithKey4
API_TOKEN_SALT=replaceWithRandomString
ADMIN_JWT_SECRET=replaceWithRandomString
TRANSFER_TOKEN_SALT=replaceWithRandomString
JWT_SECRET=replaceWithRandomString

# PostgreSQL
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Individual credentials (fallback when DATABASE_URL is not set)
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi

# SSL — true for Neon/Render/managed Postgres
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional pool tuning
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_SCHEMA=public

# Cloudinary (required for migrate:uploads-to-cloudinary and production uploads)
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
# CLOUDINARY_FOLDER=strapi-blog-cms

# =============================================================================
# Render production (set in Render Dashboard → Environment)
# =============================================================================
# NODE_VERSION=22
# NODE_ENV=production
# PUBLIC_URL=https://your-service.onrender.com
# STRAPI_ADMIN_BACKEND_URL=https://your-service.onrender.com
# SERVER_PROXY=true
# CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3000

# Render build command:  npm run render:build
# Or in Render Dashboard → Settings → Build Command:  npm run render:build
# Render start command:   npm run start
